# Example environment file for local Docker Compose runs.
# Copy to `.env` at the repository root and adjust values as needed.

COMPOSE_INTERNAL_NETWORK_NAME=hng14_internal
COMPOSE_INTERNAL_NETWORK_DRIVER=bridge

REDIS_IMAGE=redis:7-alpine
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CPU_LIMIT=0.25
REDIS_MEMORY_LIMIT=256M
REDIS_HEALTHCHECK_INTERVAL=5s
REDIS_HEALTHCHECK_TIMEOUT=3s
REDIS_HEALTHCHECK_START_PERIOD=5s
REDIS_HEALTHCHECK_RETRIES=5

API_BUILD_CONTEXT=./api
API_DOCKERFILE=Dockerfile
API_CONTAINER_PORT=8000
API_HOST_PORT_MAPPING=8000:8000
API_CPU_LIMIT=0.50
API_MEMORY_LIMIT=512M

WORKER_BUILD_CONTEXT=./worker
WORKER_DOCKERFILE=Dockerfile
WORKER_CPU_LIMIT=0.50
WORKER_MEMORY_LIMIT=256M

FRONTEND_BUILD_CONTEXT=./frontend
FRONTEND_DOCKERFILE=Dockerfile
FRONTEND_LISTEN_HOST=0.0.0.0
FRONTEND_CONTAINER_PORT=3000
FRONTEND_HOST_PORT_MAPPING=3000:3000
FRONTEND_CPU_LIMIT=0.50
FRONTEND_MEMORY_LIMIT=256M

API_URL=http://api:8000
